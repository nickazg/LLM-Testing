# Claude Code — Route to a model via OpenRouter
# Copy this to: config/claude-code.{model-id}.env
# Example:      config/claude-code.qwen3-30b.env

ANTHROPIC_BASE_URL=http://127.0.0.1:3456
ANTHROPIC_AUTH_TOKEN=sk-or-v1-YOUR_OPENROUTER_KEY_HERE

ANTHROPIC_DEFAULT_HAIKU_MODEL="openrouter,provider/model-name"
ANTHROPIC_DEFAULT_SONNET_MODEL="openrouter,provider/model-name"
ANTHROPIC_DEFAULT_OPUS_MODEL="openrouter,provider/model-name"
